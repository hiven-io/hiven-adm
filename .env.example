# Supabase (public — bundled in client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Admin (server-side — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Mapbox (public by design)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Mapbox download token (sk.*) — used by Expo Prebuild and Gradle
MAPBOX_DOWNLOAD_TOKEN=

# Supabase CLI
SUPABASE_DB_PASSWORD=
SUPABASE_ACCESS_TOKEN=
